# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL (after running: psql -U postgres < init.sql)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/hubconnect

# ── Authentication ────────────────────────────────────────────────────────────
# Must be a long random string in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin (Vite default port)
CORS_ORIGIN=http://localhost:5173
